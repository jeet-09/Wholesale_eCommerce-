# =============================================================================
# B2B Procurement Platform — Backend Environment
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values marked <FILL_ME>.
# Every variable here is validated at startup (src/config/env.ts). The app
# REFUSES TO BOOT if a required value is missing or malformed (fail-fast).
# NEVER commit a real .env file. Secrets in prod come from a secrets manager.
#
# NOTE: keep comments on their OWN lines. Do NOT put `# ...` after a value on the
# same line — Docker Compose's env_file reader can fold it into the value.
# =============================================================================

# --- Runtime --------------------------------------------------------------
# NODE_ENV: development | test | staging | production
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
# LOG_LEVEL: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- Database (PostgreSQL 15+) -------------------------------------------
# <FILL_ME> Your PostgreSQL connection string.
# Local docker (see docker-compose.yml): the value below already matches it.
# AWS RDS example:
#   postgresql://USER:PASSWORD@your-db.xxxx.rds.amazonaws.com:5432/procurement?schema=public&sslmode=require
DATABASE_URL=postgresql://procurement:procurement@localhost:5432/procurement?schema=public

# --- JWT / Auth -----------------------------------------------------------
# <FILL_ME> Generate strong secrets (min 32 chars), e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET=<FILL_ME_min_32_chars_random_string>
JWT_REFRESH_SECRET=<FILL_ME_another_min_32_chars_random_string>
# Access token lifetime (README: 15 minutes)
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token lifetime (README: 30 days)
JWT_REFRESH_EXPIRES_IN=30d

# --- Cookies (refresh-token cookie for web clients) ----------------------
# <FILL_ME> Generate: `openssl rand -base64 48`
COOKIE_SECRET=<FILL_ME_min_32_chars_random_string>
# Optional; leave unset for localhost.
# COOKIE_DOMAIN=.yourdomain.com

# --- Security: CORS + rate limiting --------------------------------------
# Comma-separated allow-list of front-end origins (NEVER use * in production).
# Single role-based web app on 3000; 4000 is the API itself (Swagger UI).
CORS_ORIGINS=http://localhost:3000,http://localhost:4000
# Requests per window (global)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
# Tighter limit on auth endpoints
AUTH_RATE_LIMIT_MAX=10

# --- Password hashing -----------------------------------------------------
BCRYPT_SALT_ROUNDS=12

# --- API docs -------------------------------------------------------------
# Serve Swagger UI at /docs (set false to disable in prod)
SWAGGER_ENABLED=true

# --- Seed (demo data) -----------------------------------------------------
# Password assigned to every demo account created by `npm run db:seed`.
SEED_DEMO_PASSWORD=Password123!

# --- AWS S3 (file/image uploads) — optional until you wire uploads --------
# Leave blank to disable S3 features.
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# e.g. https://your-bucket.s3.ap-south-1.amazonaws.com
S3_PUBLIC_BASE_URL=
