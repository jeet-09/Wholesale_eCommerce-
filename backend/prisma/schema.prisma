// =============================================================================
// B2B Restaurant Procurement Platform — Prisma Schema
// -----------------------------------------------------------------------------
// AUTHORITATIVE SOURCE: ../DATABASE.md (v2.0). This schema MUST match that doc.
//
// Conventions (DATABASE.md GLOBAL CONVENTIONS):
//   C1  Standard columns: id, createdAt, updatedAt, deletedAt (+ createdBy/updatedBy)
//   C2  All timestamps TIMESTAMPTZ, UTC.
//   C3  UUID v7 primary keys (time-ordered for index locality).
//   C4  Money DECIMAL(14,2) + currency; quantities DECIMAL(14,3). Never float.
//   C5  Soft deletes via deletedAt; soft-delete-aware uniqueness = partial unique index.
//   C6  Domain enums = native Postgres enums; runtime-editable refs = lookup tables.
//   C7  Optimistic locking via `version` on contended rows (inventories, ledgers).
//   C8  snake_case DB names (mapped here); camelCase in TS.
//
// NOTE — constraints Prisma's DSL cannot express live in ./sql/constraints.sql,
// applied immediately after `prisma migrate deploy` (npm run db:constraints):
//   * partial UNIQUE indexes (WHERE deleted_at IS NULL / WHERE is_current / status)
//   * expression unique indexes (lower(email))
//   * CHECK constraints (non-negative qty/money, reserved <= available)
//   * pg_trgm index on products.name for search
//   * FK constraints for created_by/updated_by/changed_by attribution columns
//     (kept as plain columns here to avoid bloating User with back-relations)
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, pg_trgm]
}

// =============================================================================
// ENUMS (C6)
// =============================================================================

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED

  @@map("user_status")
}

enum OrganizationType {
  RESTAURANT
  VENDOR
  FARMER
  WAREHOUSE

  @@map("organization_type")
}

enum OrganizationStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED

  @@map("organization_status")
}

enum MemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED

  @@map("member_status")
}

enum AddressType {
  BILLING
  SHIPPING
  REGISTERED

  @@map("address_type")
}

enum ProfileStatus {
  PENDING
  ACTIVE
  SUSPENDED

  @@map("profile_status")
}

enum CategoryStatus {
  ACTIVE
  INACTIVE

  @@map("category_status")
}

enum ProductUnit {
  KG
  GRAM
  LITER
  ML
  PIECE
  BOX
  PACKET

  @@map("product_unit")
}

// Master-catalog lifecycle (project-working.md PRODUCT STATES).
// Only APPROVED products are visible to restaurants.
enum ProductStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
  INACTIVE

  @@map("product_status")
}

// A vendor's price + stock submission for a master-catalog product.
// Admin reviews submissions; APPROVED offers feed the average-price calculation.
enum VendorOfferStatus {
  PENDING
  APPROVED
  REJECTED
  INACTIVE

  @@map("vendor_offer_status")
}

// Outcome recorded by Administration after calling a vendor about an order
// (project-working.md VENDOR CALL TRACKING).
enum CallOutcome {
  ACCEPTED
  REJECTED
  NO_RESPONSE
  PARTIAL

  @@map("call_outcome")
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED

  @@map("cart_status")
}

// Full procurement lifecycle (project-working.md ORDER STATUS FLOW + BUSINESS FLOW).
// PENDING_PAYMENT     order placed, 30% advance computed, awaiting payment proof
// PAYMENT_RECEIVED    restaurant uploaded advance proof, awaiting admin verification
// PENDING_ADMIN_REVIEW advance verified, awaiting Administration review + vendor assignment
// VENDOR_ASSIGNED     Administration assigned a vendor (stock reserved), awaiting response
// VENDOR_ACCEPTED     vendor accepted the order
// PROCESSING          vendor is preparing the order
// READY_FOR_DELIVERY  vendor marked the order ready
// DELIVERED           vendor delivered the goods
// COMPLETED           Administration verified completion (stock fulfilled, performance updated)
// REJECTED            vendor rejected (re-assignable) or order rejected
// CANCELLED           cancelled by restaurant/admin before fulfilment
enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAYMENT_RECEIVED
  PENDING_ADMIN_REVIEW
  VENDOR_ASSIGNED
  VENDOR_ACCEPTED
  PROCESSING
  READY_FOR_DELIVERY
  DELIVERED
  COMPLETED
  REJECTED
  CANCELLED

  @@map("order_status")
}

enum NoteVisibility {
  INTERNAL
  SHARED

  @@map("note_visibility")
}

enum IdempotencyStatus {
  IN_PROGRESS
  COMPLETED

  @@map("idempotency_status")
}

enum OutboxStatus {
  PENDING
  PROCESSED
  FAILED

  @@map("outbox_status")
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
  SUCCESS
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED

  @@map("payment_status")
}

// Phase 1 collects a 30% ADVANCE up front; BALANCE is settled on delivery.
enum PaymentType {
  ADVANCE
  BALANCE

  @@map("payment_type")
}

enum LedgerEntryType {
  DEBIT
  CREDIT

  @@map("ledger_entry_type")
}

enum DocumentType {
  GST
  PAN
  INVOICE
  LICENSE
  AGREEMENT

  @@map("document_type")
}

enum NotificationType {
  SYSTEM
  ORDER
  PAYMENT
  INVENTORY

  @@map("notification_type")
}

enum VerificationChannel {
  EMAIL
  SMS

  @@map("verification_channel")
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON

  @@map("setting_value_type")
}

enum LookupStatus {
  ACTIVE
  INACTIVE

  @@map("lookup_status")
}

// =============================================================================
// USER & AUTHENTICATION DOMAIN
// =============================================================================

model User {
  id              String     @id @default(uuid(7)) @db.Uuid
  firstName       String     @map("first_name")
  lastName        String     @map("last_name")
  email           String     @db.Citext
  phone           String?
  passwordHash    String     @map("password_hash")
  status          UserStatus @default(PENDING)
  isEmailVerified Boolean    @default(false) @map("is_email_verified")
  isPhoneVerified Boolean    @default(false) @map("is_phone_verified")
  lastLoginAt     DateTime?  @map("last_login_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  memberships         OrganizationMember[]
  userRoles           UserRole[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  verificationTokens  VerificationToken[]
  notifications       Notification[]
  idempotencyKeys     IdempotencyKey[]

  @@index([status])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid(7)) @db.Uuid
  name        String  @unique
  description String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid(7)) @db.Uuid
  key         String  @unique
  description String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@map("permissions")
}

// Pure mapping table (C1 exemption): no deletedAt / updatedBy, keeps createdAt.
model RolePermission {
  id           String @id @default(uuid(7)) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// Pure mapping table. organizationId NULL = global role.
model UserRole {
  id             String  @id @default(uuid(7)) @db.Uuid
  userId         String  @map("user_id") @db.Uuid
  roleId         String  @map("role_id") @db.Uuid
  organizationId String? @map("organization_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  role         Role          @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, roleId, organizationId])
  @@index([roleId])
  @@index([organizationId])
  @@map("user_roles")
}

model RefreshToken {
  id           String    @id @default(uuid(7)) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  familyId     String    @map("family_id") @db.Uuid
  userAgent    String?   @map("user_agent")
  ipAddress    String?   @map("ip_address") @db.Inet
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  replacedById String?   @map("replaced_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user       User           @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  replacedBy RefreshToken?  @relation("TokenRotation", fields: [replacedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  replaces   RefreshToken[] @relation("TokenRotation")

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid(7)) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model VerificationToken {
  id        String              @id @default(uuid(7)) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   VerificationChannel
  tokenHash String              @map("token_hash")
  expiresAt DateTime            @map("expires_at") @db.Timestamptz
  usedAt    DateTime?           @map("used_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@map("verification_tokens")
}

// =============================================================================
// ORGANIZATION DOMAIN
// =============================================================================

model Organization {
  id               String             @id @default(uuid(7)) @db.Uuid
  name             String
  organizationType OrganizationType   @map("organization_type")
  gstNumber        String?            @map("gst_number")
  panNumber        String?            @map("pan_number")
  email            String?            @db.Citext
  phone            String?
  website          String?
  status           OrganizationStatus @default(PENDING)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  addresses  OrganizationAddress[]
  members    OrganizationMember[]
  userRoles  UserRole[]
  restaurant Restaurant?
  vendor     Vendor?
  ledger     Ledger?
  documents  Document[]

  @@index([organizationType])
  @@index([status])
  @@map("organizations")
}

model OrganizationAddress {
  id             String      @id @default(uuid(7)) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  addressLine1   String      @map("address_line_1")
  addressLine2   String?     @map("address_line_2")
  city           String
  state          String
  country        String      @default("IN")
  pincode        String
  latitude       Decimal?    @db.Decimal(9, 6)
  longitude      Decimal?    @db.Decimal(9, 6)
  addressType    AddressType @map("address_type")
  isPrimary      Boolean     @default(false) @map("is_primary")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([organizationId])
  @@index([addressType])
  @@map("organization_addresses")
}

model OrganizationMember {
  id             String       @id @default(uuid(7)) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  designation    String?
  status         MemberStatus @default(INVITED)
  joinedAt       DateTime?    @map("joined_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@map("organization_members")
}

// =============================================================================
// RESTAURANT DOMAIN
// =============================================================================

model Restaurant {
  id                        String        @id @default(uuid(7)) @db.Uuid
  organizationId            String        @unique @map("organization_id") @db.Uuid
  restaurantName            String        @map("restaurant_name")
  licenseNumber             String?       @map("license_number")
  cuisineType               String?       @map("cuisine_type")
  averageMonthlyProcurement Decimal?      @map("average_monthly_procurement") @db.Decimal(14, 2)
  status                    ProfileStatus @default(PENDING)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  carts        Cart[]
  orders       Order[]

  @@index([status])
  @@map("restaurants")
}

// =============================================================================
// VENDOR DOMAIN
// =============================================================================

model Vendor {
  id               String        @id @default(uuid(7)) @db.Uuid
  organizationId   String        @unique @map("organization_id") @db.Uuid
  vendorName       String        @map("vendor_name")
  vendorCode       String        @unique @map("vendor_code")
  businessCategory String?       @map("business_category")
  status           ProfileStatus @default(PENDING)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  offers         VendorProductOffer[]
  assignedOrders Order[]
  callLogs       VendorCallLog[]
  performance    VendorPerformance?

  @@index([status])
  @@map("vendors")
}

// =============================================================================
// PRODUCT DOMAIN
// =============================================================================

model Category {
  id               String         @id @default(uuid(7)) @db.Uuid
  name             String
  description      String?
  slug             String         @unique
  parentCategoryId String?        @map("parent_category_id") @db.Uuid
  displayOrder     Int            @default(0) @map("display_order")
  status           CategoryStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  parent   Category?  @relation("CategoryTree", fields: [parentCategoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentCategoryId])
  @@index([status])
  @@map("categories")
}

// Master catalog product. Platform-controlled: only Admin creates/edits these
// (project-working.md MASTER PRODUCT CATALOG). Vendors never create products;
// they attach price + stock via VendorProductOffer. Restaurants see a SINGLE
// listing per product regardless of how many vendors supply it.
model Product {
  id              String        @id @default(uuid(7)) @db.Uuid
  categoryId      String        @map("category_id") @db.Uuid
  sku             String
  name            String
  description     String?
  unit            ProductUnit
  brand           String?
  status          ProductStatus @default(DRAFT)
  isFeatured      Boolean       @default(false) @map("is_featured")
  // Transportation markup added on top of the average vendor price before the
  // admin sets the final selling price. Defaults to the platform setting (20%).
  transportPercent Decimal      @default(20) @map("transport_percent") @db.Decimal(5, 2)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  category   Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  images     ProductImage[]
  prices     ProductPrice[]
  offers     VendorProductOffer[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([status])
  @@index([sku])
  @@map("products")
}

// A vendor's price + available stock for a master-catalog product
// (project-working.md PRODUCT PRICING FLOW + VENDOR Product Pricing).
//   * vendorPrice feeds the platform average (APPROVED offers only)
//   * availableQuantity/reservedQuantity track the vendor's sellable stock
//   * stock is reserved when Administration assigns this vendor to an order
// `sellable = availableQuantity - reservedQuantity` (DATABASE.md inventory rule).
model VendorProductOffer {
  id                String            @id @default(uuid(7)) @db.Uuid
  vendorId          String            @map("vendor_id") @db.Uuid
  productId         String            @map("product_id") @db.Uuid
  vendorPrice       Decimal           @map("vendor_price") @db.Decimal(14, 2)
  currency          String            @default("INR") @db.Char(3)
  availableQuantity Decimal           @default(0) @map("available_quantity") @db.Decimal(14, 3)
  reservedQuantity  Decimal           @default(0) @map("reserved_quantity") @db.Decimal(14, 3)
  status            VendorOfferStatus @default(PENDING)
  version           Int               @default(0)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([vendorId])
  @@index([productId])
  @@index([status])
  @@index([productId, status])
  @@map("vendor_product_offers")
}

model ProductImage {
  id           String  @id @default(uuid(7)) @db.Uuid
  productId    String  @map("product_id") @db.Uuid
  imageUrl     String  @map("image_url")
  altText      String? @map("alt_text")
  displayOrder Int     @default(0) @map("display_order")
  isPrimary    Boolean @default(false) @map("is_primary")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([productId])
  @@map("product_images")
}

// Append-only SELLING-price history (Rule 6) — the final price shown to
// restaurants, controlled by Admin. Each row records how it was derived:
//   price = averageVendorPrice * (1 + transportPercent/100), unless isOverride.
// Never UPDATE/DELETE except closing a row (effective_to + is_current=false)
// inside the price-change transaction.
model ProductPrice {
  id                 String    @id @default(uuid(7)) @db.Uuid
  productId          String    @map("product_id") @db.Uuid
  price              Decimal   @db.Decimal(14, 2)
  currency           String    @default("INR") @db.Char(3)
  averageVendorPrice Decimal?  @map("average_vendor_price") @db.Decimal(14, 2)
  transportPercent   Decimal?  @map("transport_percent") @db.Decimal(5, 2)
  isOverride         Boolean   @default(false) @map("is_override")
  effectiveFrom      DateTime  @map("effective_from") @db.Timestamptz
  effectiveTo        DateTime? @map("effective_to") @db.Timestamptz
  isCurrent          Boolean   @default(true) @map("is_current")
  createdBy          String?   @map("created_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([productId])
  @@map("product_prices")
}

// =============================================================================
// INVENTORY — stock lives on VendorProductOffer (availableQuantity /
// reservedQuantity / version). There is no platform-level inventory because a
// master-catalog product is supplied by many vendors; the assigned vendor's
// offer is the unit of stock. See the VendorProductOffer model above.
// =============================================================================

// =============================================================================
// CART DOMAIN
// =============================================================================

model Cart {
  id           String     @id @default(uuid(7)) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  status       CartStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items      CartItem[]

  @@index([restaurantId])
  @@index([status])
  @@map("carts")
}

model CartItem {
  id                 String  @id @default(uuid(7)) @db.Uuid
  cartId             String  @map("cart_id") @db.Uuid
  productId          String  @map("product_id") @db.Uuid
  quantity           Decimal @db.Decimal(14, 3)
  unitPriceSnapshot  Decimal @map("unit_price_snapshot") @db.Decimal(14, 2)
  subtotal           Decimal @db.Decimal(14, 2)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// =============================================================================
// ORDER DOMAIN — one order = one vendor. Immutable snapshots (Rule 5).
// total = subtotal - discount + gst + delivery
// =============================================================================

// An order is placed by a restaurant WITHOUT a vendor; Administration assigns
// the vendor later (project-working.md BUSINESS FLOW). `assignedVendorId` is
// therefore nullable until step 8. Money: total = subtotal - discount + gst +
// delivery; advanceAmount = total * advancePercent/100; remaining = total - advance.
model Order {
  id              String      @id @default(uuid(7)) @db.Uuid
  orderNumber     String      @unique @map("order_number")
  restaurantId    String      @map("restaurant_id") @db.Uuid
  assignedVendorId String?    @map("assigned_vendor_id") @db.Uuid
  assignedBy      String?     @map("assigned_by") @db.Uuid
  status          OrderStatus @default(PENDING_PAYMENT)
  currency        String      @default("INR") @db.Char(3)
  subtotal        Decimal     @db.Decimal(14, 2)
  discountAmount  Decimal     @default(0) @map("discount_amount") @db.Decimal(14, 2)
  gstAmount       Decimal     @default(0) @map("gst_amount") @db.Decimal(14, 2)
  deliveryCharges Decimal     @default(0) @map("delivery_charges") @db.Decimal(14, 2)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(14, 2)
  advancePercent  Decimal     @default(30) @map("advance_percent") @db.Decimal(5, 2)
  advanceAmount   Decimal     @map("advance_amount") @db.Decimal(14, 2)
  remainingAmount Decimal     @map("remaining_amount") @db.Decimal(14, 2)

  placedAt          DateTime? @map("placed_at") @db.Timestamptz
  paymentSubmittedAt DateTime? @map("payment_submitted_at") @db.Timestamptz
  paymentVerifiedAt DateTime? @map("payment_verified_at") @db.Timestamptz
  reviewedAt        DateTime? @map("reviewed_at") @db.Timestamptz
  assignedAt        DateTime? @map("assigned_at") @db.Timestamptz
  acceptedAt        DateTime? @map("accepted_at") @db.Timestamptz
  readyAt           DateTime? @map("ready_at") @db.Timestamptz
  deliveredAt       DateTime? @map("delivered_at") @db.Timestamptz
  completedAt       DateTime? @map("completed_at") @db.Timestamptz
  rejectedAt        DateTime? @map("rejected_at") @db.Timestamptz
  cancelledAt       DateTime? @map("cancelled_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid

  restaurant     Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assignedVendor Vendor?              @relation(fields: [assignedVendorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items          OrderItem[]
  statusHistory  OrderStatusHistory[]
  notes          OrderNote[]
  payments       Payment[]
  callLogs       VendorCallLog[]

  @@index([restaurantId])
  @@index([assignedVendorId])
  @@index([status])
  @@index([createdAt])
  @@index([assignedVendorId, status])
  @@index([restaurantId, status])
  @@map("orders")
}

model OrderItem {
  id          String      @id @default(uuid(7)) @db.Uuid
  orderId     String      @map("order_id") @db.Uuid
  productId   String      @map("product_id") @db.Uuid
  productName String      @map("product_name")
  sku         String
  unit        ProductUnit
  unitPrice   Decimal     @map("unit_price") @db.Decimal(14, 2)
  quantity    Decimal     @db.Decimal(14, 3)
  subtotal    Decimal     @db.Decimal(14, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// Append-only timeline (Rule 6).
model OrderStatusHistory {
  id        String       @id @default(uuid(7)) @db.Uuid
  orderId   String       @map("order_id") @db.Uuid
  oldStatus OrderStatus? @map("old_status")
  newStatus OrderStatus  @map("new_status")
  changedBy String?      @map("changed_by") @db.Uuid
  remarks   String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model OrderNote {
  id         String         @id @default(uuid(7)) @db.Uuid
  orderId    String         @map("order_id") @db.Uuid
  createdBy  String?        @map("created_by") @db.Uuid
  note       String
  visibility NoteVisibility @default(INTERNAL)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([orderId])
  @@map("order_notes")
}

// Idempotency guard for non-idempotent writes (order creation, payments).
model IdempotencyKey {
  id             String            @id @default(uuid(7)) @db.Uuid
  key            String
  userId         String            @map("user_id") @db.Uuid
  endpoint       String
  requestHash    String            @map("request_hash")
  responseStatus Int?              @map("response_status")
  responseBody   Json?             @map("response_body") @db.JsonB
  status         IdempotencyStatus @default(IN_PROGRESS)
  expiresAt      DateTime          @map("expires_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// =============================================================================
// RELIABLE MESSAGING DOMAIN — transactional outbox.
// =============================================================================

model OutboxEvent {
  id            String       @id @default(uuid(7)) @db.Uuid
  aggregateType String       @map("aggregate_type")
  aggregateId   String       @map("aggregate_id") @db.Uuid
  eventType     String       @map("event_type")
  payload       Json         @db.JsonB
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  availableAt   DateTime     @default(now()) @map("available_at") @db.Timestamptz
  processedAt   DateTime?    @map("processed_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([status, availableAt])
  @@map("outbox_events")
}

// =============================================================================
// PAYMENT DOMAIN — Phase 1: 30% advance via PhonePe QR + manual verification.
// =============================================================================

model PaymentMethod {
  id     String       @id @default(uuid(7)) @db.Uuid
  name   String       @unique
  code   String       @unique
  status LookupStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  payments Payment[]

  @@map("payment_methods")
}

// A payment record. In Phase 1 the restaurant uploads a screenshot (proofUrl)
// of a PhonePe/UPI transfer for the 30% ADVANCE; Administration verifies it
// manually (status SUBMITTED -> VERIFIED/REJECTED). Designed to extend to an
// online gateway later without schema rewrites.
model Payment {
  id                   String        @id @default(uuid(7)) @db.Uuid
  orderId              String        @map("order_id") @db.Uuid
  paymentMethodId      String?       @map("payment_method_id") @db.Uuid
  paymentType          PaymentType   @default(ADVANCE) @map("payment_type")
  amount               Decimal       @db.Decimal(14, 2)
  currency             String        @default("INR") @db.Char(3)
  status               PaymentStatus @default(SUBMITTED)
  proofUrl             String?       @map("proof_url")
  transactionReference String?       @map("transaction_reference")
  remarks              String?
  submittedBy          String?       @map("submitted_by") @db.Uuid
  verifiedBy           String?       @map("verified_by") @db.Uuid
  verifiedAt           DateTime?     @map("verified_at") @db.Timestamptz
  paidAt               DateTime?     @map("paid_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

// =============================================================================
// VENDOR OPERATIONS DOMAIN — call tracking & performance
// =============================================================================

// Every time Administration calls a vendor about an assigned order, the outcome
// is recorded here (project-working.md VENDOR CALL TRACKING). Append-only.
model VendorCallLog {
  id       String      @id @default(uuid(7)) @db.Uuid
  orderId  String      @map("order_id") @db.Uuid
  vendorId String      @map("vendor_id") @db.Uuid
  calledBy String?     @map("called_by") @db.Uuid
  outcome  CallOutcome
  remarks  String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([orderId])
  @@index([vendorId])
  @@map("vendor_call_logs")
}

// Rolling counters per vendor (project-working.md VENDOR PERFORMANCE FORMULA),
// updated transactionally as orders progress. Derived rates (success %,
// acceptance %, avg fulfilment time, avg rating) are computed from these.
// `version` guards concurrent updates with optimistic locking.
model VendorPerformance {
  id                     String @id @default(uuid(7)) @db.Uuid
  vendorId               String @unique @map("vendor_id") @db.Uuid
  totalAssigned          Int    @default(0) @map("total_assigned")
  totalAccepted          Int    @default(0) @map("total_accepted")
  totalRejected          Int    @default(0) @map("total_rejected")
  totalCompleted         Int    @default(0) @map("total_completed")
  totalNoResponse        Int    @default(0) @map("total_no_response")
  fulfilmentMinutesTotal Int    @default(0) @map("fulfilment_minutes_total")
  ratingSum              Int    @default(0) @map("rating_sum")
  ratingCount            Int    @default(0) @map("rating_count")
  version                Int    @default(0)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("vendor_performance")
}

// =============================================================================
// CREDIT DOMAIN (future — designed now)
// =============================================================================

model Ledger {
  id             String  @id @default(uuid(7)) @db.Uuid
  organizationId String  @unique @map("organization_id") @db.Uuid
  currentBalance Decimal @default(0) @map("current_balance") @db.Decimal(14, 2)
  creditLimit    Decimal @default(0) @map("credit_limit") @db.Decimal(14, 2)
  currency       String  @default("INR") @db.Char(3)
  version        Int     @default(0)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  entries      LedgerEntry[]

  @@map("ledgers")
}

// Append-only (Rule 6). Double-entry friendly.
model LedgerEntry {
  id            String          @id @default(uuid(7)) @db.Uuid
  ledgerId      String          @map("ledger_id") @db.Uuid
  amount        Decimal         @db.Decimal(14, 2)
  entryType     LedgerEntryType @map("entry_type")
  referenceType String          @map("reference_type")
  referenceId   String?         @map("reference_id") @db.Uuid
  description   String?
  balanceAfter  Decimal         @map("balance_after") @db.Decimal(14, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  ledger Ledger @relation(fields: [ledgerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([ledgerId])
  @@map("ledger_entries")
}

// =============================================================================
// DOCUMENT DOMAIN
// =============================================================================

model Document {
  id             String       @id @default(uuid(7)) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  documentType   DocumentType @map("document_type")
  fileUrl        String       @map("file_url")
  fileName       String       @map("file_name")
  mimeType       String       @map("mime_type")
  sizeBytes      Int          @map("size_bytes")
  uploadedBy     String?      @map("uploaded_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([organizationId])
  @@index([documentType])
  @@map("documents")
}

// =============================================================================
// NOTIFICATION DOMAIN
// =============================================================================

model Notification {
  id      String           @id @default(uuid(7)) @db.Uuid
  userId  String           @map("user_id") @db.Uuid
  title   String
  message String
  type    NotificationType
  data    Json?            @db.JsonB
  isRead  Boolean          @default(false) @map("is_read")
  readAt  DateTime?        @map("read_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// =============================================================================
// AUDIT DOMAIN (mandatory) — append-only (Rule 6).
// =============================================================================

model AuditLog {
  id         String  @id @default(uuid(7)) @db.Uuid
  userId     String? @map("user_id") @db.Uuid
  entityType String  @map("entity_type")
  entityId   String  @map("entity_id")
  action     String
  oldValue   Json?   @map("old_value") @db.JsonB
  newValue   Json?   @map("new_value") @db.JsonB
  ipAddress  String? @map("ip_address") @db.Inet
  userAgent  String? @map("user_agent")
  requestId  String? @map("request_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// SYSTEM CONFIGURATION DOMAIN
// =============================================================================

model Setting {
  id          String           @id @default(uuid(7)) @db.Uuid
  key         String           @unique
  value       String
  valueType   SettingValueType @map("value_type")
  description String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  @@map("settings")
}
